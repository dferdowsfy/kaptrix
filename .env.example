# Kaptrix Delivery Platform — Environment Variables
# Copy to .env.local and fill in values. On Vercel, configure each of
# these in Project Settings → Environment Variables for every environment
# (Production / Preview / Development).

# ─── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional newer publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=

# ─── Google Gemini (all AI functionality) ──────────────────────────────
# Obtain from https://aistudio.google.com/app/apikey
# Also accepted: GEMINI_API_KEY (same value).
GOOGLE_API_KEY=your-gemini-api-key

# ─── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
